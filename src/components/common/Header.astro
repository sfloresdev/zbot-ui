---
import SearchBar from "../features/SearchBar.svelte";
import UserProfile from "../features/auth/UserProfile.svelte";
import Notifications from "../features/auth/Notifications.svelte";
---

<header class="sticky top-0 z-30 w-full border-b border-white/10 bg-black">
  <div class="flex h-16 w-full items-center justify-between px-4 sm:px-6 lg:px-8">
    {/* Controles Izquierdos: Barra de búsqueda y Nav móvil */}
    <div class="flex items-center gap-3">
      {/* Botón menú móvil con Javascript Nativo */}
      <button id="mobile-menu-btn" class="md:hidden flex h-9 w-9 items-center justify-center border border-white/20 text-white/70 hover:bg-white/10 hover:text-white transition-colors cursor-pointer" aria-label="Alternar menú">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>

      {/* Placeholder de Logo de Empresa Exclusivo Móvil */}
      <a href="/" class="md:hidden flex h-9 w-9 items-center justify-center border-2 border-dashed border-white/50 bg-black text-white/80 font-bold text-sm font-sans transition-transform hover:scale-105 hover:border-white hover:text-white" title="Inicio">
        Z
      </a>

      <SearchBar client:media="(max-width: 949px)" />
    </div>

    {/* Controles Derechos: Entorno de usuario */}
    <div class="flex items-center gap-3 sm:gap-6">
      
      {/* Menú Interactivo de Notificaciones */}
      <Notifications client:load />

      <!-- Perfil Componentizado SSR/Client -->
      <UserProfile client:load />

    </div>
  </div>
</header>

<script is:inline>
  // Event listener hook for Astro page transitions to keep logic working smoothly
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-menu-btn');
    const sidebar = document.getElementById('app-sidebar');

    if (btn && sidebar) {
      btn.addEventListener('click', (e) => {
        // Stop propagation just in case
        e.stopPropagation();
        sidebar.classList.toggle('-translate-x-full');
      });
      
      // Close sidebar when clicking outside on mobile
      document.addEventListener('click', (e) => {
        if (window.innerWidth < 768 && !sidebar.classList.contains('-translate-x-full')) {
            if (!sidebar.contains(e.target) && !btn.contains(e.target)) {
                sidebar.classList.add('-translate-x-full');
            }
        }
      });
    }
  });
</script>
