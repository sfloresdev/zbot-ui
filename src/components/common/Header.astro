---
import MobileNav from "../features/MobileNav.svelte";
import SearchBar from "../features/SearchBar.svelte";

// Opciones de navegación dinámicas, para que en el futuro sea fácil iterar.
const navItems = [
  { label: "Dashboard", href: "/" },
  { label: "Documentos", href: "#" },
  { label: "Soporte", href: "#" },
  { label: "Acceder", href: "/login" },
];
---

<header
  class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/80 backdrop-blur-md supports-[backdrop-filter]:bg-background/60"
>
  <div
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    {/* Bloque Izquierdo y Central: Logo y Buscador */}
    <div class="flex flex-1 items-center gap-4 lg:gap-12">
      {/* Botón menú móvil: Solo carga JS en pantallas pequeñas (<768px) */}
      <MobileNav client:media="(max-width: 767px)" navItems={navItems} />

      <a
        href="/"
        class="flex items-center gap-2 pr-0 sm:pr-4 transition-opacity hover:opacity-80"
      >
        <!-- Placeholder para el logo de la empresa -->
        <div
          class="flex h-9 w-9 items-center justify-center rounded-xl bg-brand text-background font-bold font-heading shadow-sm shadow-brand/20"
        >
          Z
        </div>
        <span
          class="hidden sm:inline font-heading font-bold text-xl tracking-tight"
          >Zaltor Intra</span
        >
      </a>

      {
        /* Buscador Interactivo: Solo carga JS en pantallas medianas/pequeñas (<950px) */
      }
      <SearchBar client:media="(max-width: 949px)" />
    </div>

    {/* Bloque Derecho: Navegación y Perfil */}
    <div class="flex items-center gap-4 sm:gap-6">
      {
        /* Navegación (las cuatro utilidades) alineada a la derecha - Oculto en móvil */
      }
      <nav
        class="hidden md:flex items-center gap-6 pr-4 border-r border-border/50"
      >
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="text-sm font-medium text-foreground/70 transition-colors hover:text-brand"
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      {/* Botón de Perfil o Menú de usuario (Placeholder) */}
      <button
        class="hidden md:flex flex h-9 w-9 shrink-0 items-center justify-center rounded-full border border-border/50 bg-surface text-foreground shadow-sm transition-colors hover:bg-border/50 focus:outline-none focus:ring-2 focus:ring-brand focus:ring-offset-2 focus:ring-offset-background"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-foreground/80"
          ><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle
            cx="12"
            cy="7"
            r="4"></circle></svg
        >
      </button>
    </div>
  </div>
</header>
