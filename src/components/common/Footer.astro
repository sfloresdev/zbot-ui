---
import StatusIndicator from "../features/StatusIndicator.svelte";
import Clock from "./Clock.astro";

const currentYear = new Date().getFullYear();
---

<footer class="w-full mt-auto">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-4">
      {/* Columna 1: Logo y descripción */}
      <div class="flex flex-col gap-4 lg:col-span-2 h-full">
        <a
          href="/"
          class="flex w-fit items-center gap-2 transition-opacity hover:opacity-80"
        >
          <div
            class="flex h-9 w-9 items-center justify-center rounded-xl bg-brand text-background font-bold font-heading shadow-sm shadow-brand/20"
          >
            Z
          </div>
          <span class="font-heading font-bold text-xl tracking-tight"
            >Zaltor Intra</span
          >
        </a>
        <p class="text-sm text-foreground/60 max-w-xs leading-relaxed">
          La plataforma central de herramientas, documentación y recursos
          internos para el equipo productivo de Zaltor.
        </p>

        <div class="mt-auto pt-2">
          <StatusIndicator client:load status="operational" />
        </div>
      </div>

      {/* Columna 2: Recursos y Empleados */}
      <div class="flex flex-col gap-3">
        <h3 class="font-heading font-semibold text-foreground tracking-tight">
          Recursos
        </h3>
        <nav class="flex flex-col gap-2.5">
          <a
            href="#"
            class="text-sm font-medium text-foreground/60 hover:text-brand transition-colors"
            >Documentación Interna</a
          >
          <a
            href="#"
            class="text-sm font-medium text-foreground/60 hover:text-brand transition-colors"
            >Directorio de Empleados</a
          >
          <a
            href="#"
            class="text-sm font-medium text-foreground/60 hover:text-brand transition-colors"
            >Soporte IT</a
          >
        </nav>
      </div>

      {/* Columna 3: Herramientas de Desarrollo */}
      <div class="flex flex-col gap-3 h-full">
        <div>
          <h3
            class="font-heading font-semibold text-foreground tracking-tight mb-3"
          >
            Tecnología
          </h3>
          <nav class="flex flex-col gap-2.5">
            <a
              href="#"
              class="text-sm font-medium text-foreground/60 hover:text-brand transition-colors"
              >Portal Desarrollador</a
            >
            <a
              href="#"
              class="text-sm font-medium text-foreground/60 hover:text-brand transition-colors"
              >Documentación API</a
            >
            <a
              href="#"
              class="text-sm font-medium text-foreground/60 hover:text-brand transition-colors"
              >Test</a
            >
          </nav>
        </div>

        <div class="mt-auto pt-4 flex justify-end">
          <Clock />
        </div>
      </div>
    </div>

    {/* Barra Inferior (Copyright e Información General) */}
    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border/40 pt-8 sm:flex-row"
    >
      <p class="text-sm text-foreground/50">
        &copy; {currentYear} Zaltor. Todos los derechos reservados.
      </p>
      <div class="flex items-center gap-6">
        <a
          href="#"
          class="text-sm text-foreground/50 hover:text-foreground transition-colors"
          >Mayorista Soluciones TI</a
        >
        <a
          href="#"
          class="text-sm text-foreground/50 hover:text-foreground transition-colors"
          >España · Portugal</a
        >
      </div>
    </div>
  </div>
</footer>
