---
// src/components/common/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="w-full mt-auto border-t border-white/5 overflow-hidden">
  <div class="flex flex-col items-center justify-center pt-24 pb-16 px-4">
    
    <!-- Logo Sutil Gigante (Watermark Style) -->
    <div class="w-full flex justify-center mb-16 sm:mb-24 select-none">
      <h2 
        class="text-6xl sm:text-[100px] lg:text-[130px] font-black uppercase tracking-[0.2em] text-white/5 hover:text-white/10 transition-colors duration-1000 cursor-default leading-none"
        style="font-family: 'Inter', sans-serif; padding-left: 0.2em;"
      >
        Zaltor<span class="text-brand/30 hover:text-brand/60 transition-colors duration-500">.</span>
      </h2>
    </div>
    
    <!-- Legal Info -->
    <div 
        class="flex flex-wrap items-center justify-center text-[10px] sm:text-xs text-white/40 tracking-wider uppercase font-medium gap-8 sm:gap-12"
        style="font-family: 'Geist', sans-serif;"
    >
        <a href="#" class="hover:text-white transition-colors">Soporte</a>
        <span class="w-1 h-1 rounded-full bg-white/20 hidden sm:block"></span>
        <a href="#" class="hover:text-white transition-colors">Aviso Legal</a>
        <span class="w-1 h-1 rounded-full bg-white/20 hidden sm:block"></span>
        <span>&copy; {currentYear} Zaltor</span>
    </div>

  </div>
</footer>
