---
import "../styles/global.css";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";

interface Props {
  title: string;
  requiresAdmin?: boolean;
}

const { title, requiresAdmin = false } = Astro.props;
const isLoginPage = Astro.url.pathname === "/login";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <script is:inline>
      (function () {
        const session = localStorage.getItem("zbot-session");
        const path = window.location.pathname;

        if (!session || !JSON.parse(session).isAuthenticated) {
          if (path !== "/login") window.location.href = "/login";
          return;
        }

        const auth = JSON.parse(session);

        if (auth.isAuthenticated && path === '/login') {
          window.location.href = '/';
          return ;
        }

        const needsAdmin = document.documentElement.dataset.adminRequired === 'true';
        if (needsAdmin && auth.role !== 'admin'){
          window.location.href = '/403';
        }
      })();
    </script>
  </head>
  <body
    class="flex min-h-screen flex-col selection:bg-brand/20 selection:text-brand"
    data-admin-required={requiresAdmin.toString()}
  >
    {!isLoginPage && <Header />}
    
    <main
      class:list={[
        "flex-1 flex flex-col",
        !isLoginPage && "max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8",
        isLoginPage && "items-center justify-center p-4 bg-background" 
      ]}
    >
      <slot />
    </main>

    {!isLoginPage && <Footer />}
  </body>
</html>
