---
import "../styles/global.css";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import Sidebar from "../components/common/Sidebar.svelte";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  requiresAdmin?: boolean;
}

const { title, requiresAdmin = false } = Astro.props;
const isAuthPage = Astro.url.pathname === "/login" || Astro.url.pathname === "/recover";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />

    <script is:inline>
      (function () {
        const session = localStorage.getItem("zbot-session");
        const path = window.location.pathname;

        /* PERMITIR RUTAS PÚBLICAS: /login, /recover */
        if (!session || !JSON.parse(session).isAuthenticated) {
          if (path !== "/login" && path !== "/recover") {
            window.location.href = "/login";
          }
          return;
        }

        const auth = JSON.parse(session);

        /* EVITAR RUTAS AUTH SI YA ESTÁ LOGUEADO */
        if (auth.isAuthenticated && (path === '/login' || path === '/recover')) {
          window.location.href = '/';
          return ;
        }

        const needsAdmin = document.documentElement.dataset.adminRequired === 'true';
        if (needsAdmin && auth.role !== 'admin'){
          window.location.href = '/403';
        }
      })();
    </script>
  </head>
  <body
    class="flex min-h-screen selection:bg-brand/20 selection:text-brand bg-black text-white"
    data-admin-required={requiresAdmin.toString()}
  >
    {isAuthPage ? (
      <main class="flex-1 flex flex-col items-center justify-center p-4 z-10 relative">
        <slot />
      </main>
    ) : (
      <div class="flex h-screen w-full overflow-hidden bg-black">
        {/* App Shell Sidebar: rendered fully statically by Astro */}
        <Sidebar />
        
        {/* Main Content Area */}
        <div class="flex flex-col flex-1 min-w-0 overflow-hidden relative">
          <Header />
          <main class="flex-1 overflow-y-auto">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full min-h-full flex flex-col">
              <div class="flex-1">
                <slot />
              </div>
              
              {/* Footer always sits at the bottom of the content */}
              <div class="mt-16">
                <Footer />
              </div>
            </div>
          </main>
        </div>
      </div>
    )}
  </body>
</html>
